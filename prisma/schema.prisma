// ═══════════════════════════════════════════════════════════════════════════
// ─── SubRadar — Subscription Intelligence ─────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════

/// A Gmail account connected by an end-user for subscription scanning.
/// Tokens are stored AES-256-GCM encrypted (same pattern as ConnectedSource).
model GmailAccount {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  endUserId           String    @map("end_user_id") @db.Uuid
  email               String
  encryptedRefreshToken String  @map("encrypted_refresh_token") @db.Text
  scopes              String[]  @default([])
  lastScanAt          DateTime? @map("last_scan_at") @db.Timestamptz
  isActive            Boolean   @default(true) @map("is_active")
  connectedAt         DateTime  @default(now()) @map("connected_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endUser             EndUser             @relation("EndUserGmailAccounts", fields: [endUserId], references: [id])
  trackedSubscriptions TrackedSubscription[]

  @@unique([orgId, endUserId, email])
  @@index([orgId, endUserId])
  @@map("gmail_accounts")
}

/// A recurring subscription detected from Gmail or added manually.
model TrackedSubscription {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                 String                @map("org_id") @db.Uuid
  endUserId             String                @map("end_user_id") @db.Uuid
  gmailAccountId        String?               @map("gmail_account_id") @db.Uuid
  serviceName           String                @map("service_name") @db.VarChar(120)
  domain                String?               @db.VarChar(253)
  logoUrl               String?               @map("logo_url")
  category              String                @db.VarChar(60) // streaming, productivity, ai_tools, fitness, etc.
  amountPaise           Int                   @map("amount_paise") // stored in paise (₹ × 100) for accuracy
  currency              String                @default("INR") @db.VarChar(3)
  billingCycle          TrackedBillingCycle   @map("billing_cycle")
  nextRenewalAt         DateTime?             @map("next_renewal_at") @db.Timestamptz
  firstSeenAt           DateTime?             @map("first_seen_at") @db.Timestamptz
  lastSeenAt            DateTime?             @map("last_seen_at") @db.Timestamptz
  lastActivityAt        DateTime?             @map("last_activity_at") @db.Timestamptz
  source                TrackedSubSource      @default(gmail_auto)
  status                TrackedSubStatus      @default(active)
  isFreeTrialDetected   Boolean               @default(false) @map("is_free_trial_detected")
  freeTrialEndsAt       DateTime?             @map("free_trial_ends_at") @db.Timestamptz
  notes                 String?               @db.Text
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?             @map("deleted_at") @db.Timestamptz

  organization          Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endUser               EndUser               @relation("EndUserTrackedSubscriptions", fields: [endUserId], references: [id])
  gmailAccount          GmailAccount?         @relation(fields: [gmailAccountId], references: [id])
  alerts                SubscriptionAlert[]
  suggestions           SubscriptionSuggestion[]

  @@index([orgId, endUserId])
  @@index([orgId, endUserId, status])
  @@index([orgId, endUserId, nextRenewalAt])
  @@index([deletedAt])
  @@map("tracked_subscriptions")
}

enum TrackedBillingCycle {
  monthly
  quarterly
  half_yearly
  yearly
  weekly
  lifetime
}

enum TrackedSubSource {
  gmail_auto
  manual
}

enum TrackedSubStatus {
  active
  cancelled
  paused
  forgotten // 60+ days no activity signal
  free_trial
}

/// Alerts generated for a tracked subscription (renewal, trial expiry, price change).
model SubscriptionAlert {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                  String              @map("org_id") @db.Uuid
  endUserId              String              @map("end_user_id") @db.Uuid
  trackedSubscriptionId  String              @map("tracked_subscription_id") @db.Uuid
  alertType              SubAlertType        @map("alert_type")
  daysUntilRenewal       Int?                @map("days_until_renewal") // 7, 3, 1
  amountPaise            Int?                @map("amount_paise")
  previousAmountPaise    Int?                @map("previous_amount_paise") // for price_change alerts
  scheduledAt            DateTime            @map("scheduled_at") @db.Timestamptz
  sentAt                 DateTime?           @map("sent_at") @db.Timestamptz
  isDismissed            Boolean             @default(false) @map("is_dismissed")
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz

  organization           Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endUser                EndUser             @relation("EndUserSubscriptionAlerts", fields: [endUserId], references: [id])
  trackedSubscription    TrackedSubscription @relation(fields: [trackedSubscriptionId], references: [id], onDelete: Cascade)

  @@index([orgId, endUserId])
  @@index([orgId, endUserId, isDismissed])
  @@index([scheduledAt])
  @@map("subscription_alerts")
}

enum SubAlertType {
  renewal_7d
  renewal_3d
  renewal_1d
  free_trial_expiry
  price_increase
  price_decrease
}

/// Suggestions generated by the engine (cheaper alternatives, downgrade, cancel).
model SubscriptionSuggestion {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                  String              @map("org_id") @db.Uuid
  endUserId              String              @map("end_user_id") @db.Uuid
  trackedSubscriptionId  String              @map("tracked_subscription_id") @db.Uuid
