# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techzunction

# ─── JWT (RS256 key pair) ────────────────────────────────────────────────────
# Generate with: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#                openssl rsa -pubout -in private.pem -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Encryption (64-char hex string = 32 bytes for AES-256) ─────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── CORS (comma-separated origins) ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Seed Script ─────────────────────────────────────────────────────────────
SEED_SUPER_ADMIN_EMAIL=admin@build.withdarsh.com
SEED_SUPER_ADMIN_PASSWORD=

# ─── Ably (real-time for PlayFlix rooms) ──────────────────────────────────────
# Get from https://ably.com — needs publish + subscribe capabilities
ABLY_API_KEY=

# ─── Docker Compose (optional) ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=techzunction

# ─── Dakshina broker (cross-app Razorpay payments via /api/dakshina-broker/*) ────
# Reuses RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET above for the actual Razorpay
# calls; the broker secret below is shared with Khwahish (originator) and the
# Website (iframe host) for AES-256-GCM token encryption.
DAKSHINA_BROKER_SECRET=
