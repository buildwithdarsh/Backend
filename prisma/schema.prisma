generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

  // Neon pooler default is 5 connections / 10s timeout — too low for
  // concurrent cron jobs + API traffic. Override via query-string params
  // on DATABASE_URL:  &connection_limit=10&pool_timeout=20
}

// ─── System Tables (no org_id) ──────────────────────────────────────────────

model Organization {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String
  slug                     String    @unique
  storefrontKey            String    @unique @map("storefront_key") @db.VarChar(48)
  logoUrl                  String?   @map("logo_url")
  planId                   String?   @map("plan_id") @db.Uuid
  status                   OrgStatus @default(trial)
  billingEmail             String?   @map("billing_email")
  billingName              String?   @map("billing_name")
  gstNumber                String?   @map("gst_number")
  trialEndsAt              DateTime? @map("trial_ends_at") @db.Timestamptz
  planExpiresAt            DateTime? @map("plan_expires_at") @db.Timestamptz
  metadata                 Json?     @default("{}")
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime? @map("deleted_at") @db.Timestamptz

  plan                     Plan?              @relation(fields: [planId], references: [id])
  orgConfig                OrgConfig?
  users                    User[]
  roles                    Role[]
  userRoles                UserRole[]
  endUsers                 EndUser[]
  segments                 Segment[]
  segmentMembers           SegmentMember[]
  apiKeys                  ApiKey[]
  oauthAccounts            OauthAccount[]
  magicLinks               MagicLink[]
  otpVerifications         OtpVerification[]
  refreshTokens            RefreshToken[]
  notifications            Notification[]
  notificationTemplates    NotificationTemplate[]
  campaigns                Campaign[]
  campaignLogs             CampaignLog[]
  webhooks                 Webhook[]
  webhookLogs              WebhookLog[]
  paymentProviders         PaymentProvider?
  paymentCustomers         PaymentCustomer[]
  products                 Product[]
  orders                   Order[]
  subscriptions            Subscription[]
  payments                 Payment[]
  refunds                  Refund[]
  paymentLinks             PaymentLink[]
  usageLogs                UsageLog[]
  invoices                 Invoice[]
  auditLogs                AuditLog[]
  // ─── Phase 0 Relations ───────────────────────────────────────────────────
  orgSettings              OrgSettings[]
  endUserRefreshTokens     EndUserRefreshToken[]
  endUserOtpVerifications  EndUserOtpVerification[]
  endUserAddresses         EndUserAddress[]
  // ─── Phase 1 Relations ───────────────────────────────────────────────────
  catalogCategories        CatalogCategory[]
  catalogItems             CatalogItem[]
  catalogItemVariants      CatalogItemVariant[]
  catalogSizeVariations    CatalogSizeVariation[]
  catalogOptionGroups      CatalogOptionGroup[]
  catalogOptions           CatalogOption[]
  catalogItemTaxes         CatalogItemTax[]
  catalogLocationItems     CatalogLocationItem[]
  // ─── Phase 2 Relations ───────────────────────────────────────────────────
  carts                    Cart[]
  commerceOrders           CommerceOrder[]
  // ─── Phase 3 Relations ───────────────────────────────────────────────────
  loyaltyAccounts          LoyaltyAccount[]
  loyaltyTransactions      LoyaltyTransaction[]
  loyaltyRewards           LoyaltyReward[]
  loyaltyRedemptions       LoyaltyRedemption[]
  discountCoupons          DiscountCoupon[]
  discountCouponUsages     DiscountCouponUsage[]
  promotions               Promotion[]
  referrals                Referral[]
  // ─── Phase 4 Relations ───────────────────────────────────────────────────
  storeLocations           StoreLocation[]
  storeHours               StoreHours[]
  deliveryZones            DeliveryZone[]
  posSyncLogs              PosSyncLog[]
  // ─── Phase 5 Relations ───────────────────────────────────────────────────
  reviews                  Review[]
  reviewVotes              ReviewVote[]
  giftCards                GiftCard[]
  giftCardTransactions     GiftCardTransaction[]
  bookableResources        BookableResource[]
  reservationSlots         ReservationSlot[]
  reservations             Reservation[]
  supportTickets           SupportTicket[]
  contactMessages          ContactMessage[]
  contentPosts             ContentPost[]
  // ─── Phase 6 Relations ───────────────────────────────────────────────────
  conversationSessions     ConversationSession[]
  conversationMessages     ConversationMessage[]
  // ─── Hospitality Relations ───────────────────────────────────────────────
  propertyTypes            PropertyType[]
  propertyUnits            PropertyUnit[]
  propertyAmenities        PropertyAmenity[]
  propertyTypeAmenities    PropertyTypeAmenity[]
  propertyInventory        PropertyInventory[]
  propertyInventoryHolds   PropertyInventoryHold[]
  propertyPricingRules     PropertyPricingRule[]
  propertyBookings         PropertyBooking[]
  propertyBookingUnits     PropertyBookingUnit[]
  propertyPayments         PropertyPayment[]
  // ─── InstaMovieMart Relations ──────────────────────────────────────────────
  movieDetails             MovieDetail[]
  movieCredits             MovieCredit[]
  movieEntitlements        MovieEntitlement[]
  watchProgress            WatchProgress[]
  watchlists               Watchlist[]
  heroBanners              HeroBanner[]
  movieStreamMappings      MovieStreamMapping[]
  walletBalances           WalletBalance[]
  walletTransactions       WalletTransaction[]
  watchSessions            WatchSession[]
  playFlixRooms            PlayFlixRoom[]
  hostEarnings             HostEarning[]
  connectedSources         ConnectedSource[]
  // ─── Commerce Inventory & Supply Chain ──────────────────────────────────
  ingredients              Ingredient[]
  stockAlerts              StockAlert[]
  wasteLogs                WasteLog[]
  suppliers                Supplier[]
  purchaseOrders           PurchaseOrder[]
  purchaseOrderItems       PurchaseOrderItem[]
  // ─── Meal Plans & Subscriptions ─────────────────────────────────────────
  mealPlans                MealPlan[]
  mealSubscriptions        MealSubscription[]
  // ─── Aurum Banking ────────────────────────────────────────────────────
  kycVerifications         KycVerification[]
  bankAccounts             BankAccount[]
  bankTransactions         BankTransaction[]
  beneficiaries            Beneficiary[]
  bankCards                BankCard[]
  fixedDeposits            FixedDeposit[]
  scheduledTransfers       ScheduledTransfer[]
  billPayments             BillPayment[]
  budgets                  Budget[]
  spendingCategories       SpendingCategory[]
  anomalyAlerts            AnomalyAlert[]
  // ─── SubRadar ──────────────────────────────────────────────────────────
  gmailAccounts            GmailAccount[]
  trackedSubscriptions     TrackedSubscription[]
  subscriptionAlerts       SubscriptionAlert[]
  subscriptionSuggestions  SubscriptionSuggestion[]
  serviceCatalog           ServiceCatalog[]
  // ─── Verification ──────────────────────────────────────────────────────
  verifications            Verification[]
  // ─── Shopify SpinWheel ─────────────────────────────────────────────────
  spinWheelCampaigns       SpinWheelCampaign[]
  spinWheelSlices          SpinWheelSlice[]
  spinWheelSpins           SpinWheelSpin[]
  spinWheelAnalytics       SpinWheelAnalytics[]
  spinWheelShops           SpinWheelShop[]

  @@map("organizations")
}

enum OrgStatus {
  active
  suspended
  trial
  cancelled
}

model Plan {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String
  slug                     String   @unique
  priceMonthlyInr          Decimal? @map("price_monthly_inr") @db.Decimal(10, 2)
  priceYearlyInr           Decimal? @map("price_yearly_inr") @db.Decimal(10, 2)
  razorpayPlanIdMonthly    String?  @map("razorpay_plan_id_monthly")
  razorpayPlanIdYearly     String?  @map("razorpay_plan_id_yearly")
  stripePriceIdMonthly     String?  @map("stripe_price_id_monthly")
  stripePriceIdYearly      String?  @map("stripe_price_id_yearly")
  features                 Json     @default("{}")
  isActive                 Boolean  @default(true) @map("is_active")
  isCustom                 Boolean  @default(false) @map("is_custom")
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organizations            Organization[]

  @@map("plans")
}

model SuperAdmin {
  id                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String
  email                    String          @unique
  passwordHash             String          @map("password_hash")
  role                     SuperAdminRole  @default(super_admin)
  lastLoginAt              DateTime?       @map("last_login_at") @db.Timestamptz
  isActive                 Boolean         @default(true) @map("is_active")
  createdAt                DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime?       @map("deleted_at") @db.Timestamptz

  platformConfigs          PlatformConfig[]

  @@map("super_admins")
}

enum SuperAdminRole {
  super_admin
  support
  finance
}

model PlatformConfig {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  group                    String   @db.VarChar(50)
  key                      String   @db.VarChar(100)
  value                    String   @db.Text
  isSecret                 Boolean  @default(true) @map("is_secret")
  description              String?  @db.Text
  updatedBy                String?  @map("updated_by") @db.Uuid
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz

  updatedByAdmin           SuperAdmin? @relation(fields: [updatedBy], references: [id])

  @@unique([group, key])
  @@map("platform_configs")
}

// ─── Org-scoped Tables ──────────────────────────────────────────────────────

model OrgConfig {
  id                          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                       String   @unique @map("org_id") @db.Uuid
  // Active providers
  activePaymentProvider       String?  @map("active_payment_provider") @db.VarChar(20)
  activeOtpProvider           String?  @map("active_otp_provider") @db.VarChar(20)
  activeEmailProvider         String?  @map("active_email_provider") @db.VarChar(20)
  activeSmsProvider           String?  @map("active_sms_provider") @db.VarChar(20)
  activeWhatsappProvider      String?  @map("active_whatsapp_provider") @db.VarChar(20)
  activePushProvider          String?  @map("active_push_provider") @db.VarChar(20)
  activeStorageProvider       String?  @map("active_storage_provider") @db.VarChar(20)
  // OTP
  otpMsg91AuthKey             String?  @map("otp_msg91_auth_key") @db.Text
  otpTwilioAccountSid         String?  @map("otp_twilio_account_sid") @db.Text
  otpTwilioAuthToken          String?  @map("otp_twilio_auth_token") @db.Text
  otpTwilioFromNumber         String?  @map("otp_twilio_from_number") @db.Text
  // Email
  emailFromName               String?  @map("email_from_name") @db.VarChar(255)
  emailFromAddress            String?  @map("email_from_address") @db.VarChar(255)
  emailMsg91AuthKey           String?  @map("email_msg91_auth_key") @db.Text
  emailSmtpHost               String?  @map("email_smtp_host") @db.Text
  emailSmtpPort               Int?     @map("email_smtp_port")
  emailSmtpUser               String?  @map("email_smtp_user") @db.Text
  emailSmtpPass               String?  @map("email_smtp_pass") @db.Text
  emailSmtpSecure             Boolean  @default(true) @map("email_smtp_secure")
  emailResendApiKey           String?  @map("email_resend_api_key") @db.Text
  // SMS
  smsMsg91AuthKey             String?  @map("sms_msg91_auth_key") @db.Text
  smsMsg91SenderId            String?  @map("sms_msg91_sender_id") @db.VarChar(20)
  smsTwilioAccountSid         String?  @map("sms_twilio_account_sid") @db.Text
  smsTwilioAuthToken          String?  @map("sms_twilio_auth_token") @db.Text
  smsTwilioFromNumber         String?  @map("sms_twilio_from_number") @db.Text
  // WhatsApp
  whatsappMsg91AuthKey        String?  @map("whatsapp_msg91_auth_key") @db.Text
  whatsappMsg91Number         String?  @map("whatsapp_msg91_number") @db.Text
  // Payment — Razorpay
  paymentRazorpayKeyId        String?  @map("payment_razorpay_key_id") @db.Text
  paymentRazorpayKeySecret    String?  @map("payment_razorpay_key_secret") @db.Text
  paymentRazorpayWebhookSecret String? @map("payment_razorpay_webhook_secret") @db.Text
  // Payment — Stripe
  paymentStripePublishableKey String?  @map("payment_stripe_publishable_key") @db.Text
  paymentStripeSecretKey      String?  @map("payment_stripe_secret_key") @db.Text
  paymentStripeWebhookSecret  String?  @map("payment_stripe_webhook_secret") @db.Text
  // Push (FCM)
  pushFcmServerKey            String?  @map("push_fcm_server_key") @db.Text
  pushFcmProjectId            String?  @map("push_fcm_project_id") @db.VarChar(255)
  // Storage
  storageS3AccessKey          String?  @map("storage_s3_access_key") @db.Text
  storageS3SecretKey          String?  @map("storage_s3_secret_key") @db.Text
  storageS3Bucket             String?  @map("storage_s3_bucket") @db.VarChar(255)
  storageS3Region             String?  @map("storage_s3_region") @db.VarChar(50)
  storageR2AccessKey          String?  @map("storage_r2_access_key") @db.Text
  storageR2SecretKey          String?  @map("storage_r2_secret_key") @db.Text
  storageR2Bucket             String?  @map("storage_r2_bucket") @db.VarChar(255)
  storageR2Endpoint           String?  @map("storage_r2_endpoint") @db.VarChar(500)
  // Cloudinary (per-org override, falls back to platform config)
  cloudinaryCloudName         String?  @map("cloudinary_cloud_name") @db.VarChar(100)
  cloudinaryApiKey            String?  @map("cloudinary_api_key") @db.Text
  cloudinaryApiSecret         String?  @map("cloudinary_api_secret") @db.Text
  cloudinaryFolder            String?  @map("cloudinary_folder") @db.VarChar(100) // defaults to org slug
  // OAuth
  oauthGoogleClientId         String?  @map("oauth_google_client_id") @db.Text
  oauthGoogleClientSecret     String?  @map("oauth_google_client_secret") @db.Text
  oauthGithubClientId         String?  @map("oauth_github_client_id") @db.Text
  oauthGithubClientSecret     String?  @map("oauth_github_client_secret") @db.Text
  // General
  allowedOrigins              String[] @map("allowed_origins")
  ipWhitelist                 String[] @map("ip_whitelist")
  featureOverrides            Json?    @map("feature_overrides") @default("{}")
  updatedBy                   String?  @map("updated_by") @db.Uuid
  createdAt                   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  updatedByUser               User?        @relation(fields: [updatedBy], references: [id])

  @@map("org_configs")
}

model User {
  id                       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                    String     @map("org_id") @db.Uuid
  name                     String
  email                    String
  phone                    String?
  avatarUrl                String?    @map("avatar_url")
  passwordHash             String?    @map("password_hash")
  isEmailVerified          Boolean    @default(false) @map("is_email_verified")
  isPhoneVerified          Boolean    @default(false) @map("is_phone_verified")
  status                   UserStatus @default(active)
  lastLoginAt              DateTime?  @map("last_login_at") @db.Timestamptz
  lastLoginIp              String?    @map("last_login_ip")
  metadata                 Json?      @default("{}")
  createdAt                DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime?  @map("deleted_at") @db.Timestamptz

  organization             Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userRoles                UserRole[]
  oauthAccounts            OauthAccount[]
  refreshTokens            RefreshToken[]
  notifications            Notification[]         @relation("UserNotifications")
  createdRoles             Role[]                 @relation("RoleCreator")
  createdApiKeys           ApiKey[]               @relation("ApiKeyCreator")
  createdSegments          Segment[]              @relation("SegmentCreator")
  createdTemplates         NotificationTemplate[] @relation("TemplateCreator")
  createdCampaigns         Campaign[]             @relation("CampaignCreator")
  createdWebhooks          Webhook[]              @relation("WebhookCreator")
  createdProducts          Product[]              @relation("ProductCreator")
  createdPaymentLinks      PaymentLink[]          @relation("PaymentLinkCreator")
  initiatedRefunds         Refund[]               @relation("RefundInitiator")
  paymentCustomers         PaymentCustomer[]      @relation("PaymentCustomerUser")
  orders                   Order[]                @relation("OrderUser")
  subscriptions            Subscription[]         @relation("SubscriptionUser")
  payments                 Payment[]              @relation("PaymentUser")
  orgConfigUpdates         OrgConfig[]
  assignedRoles            UserRole[]             @relation("RoleAssigner")
  verifications            Verification[]

  @@unique([orgId, email])
  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([deletedAt])
  @@map("users")
}

enum UserStatus {
  active
  invited
  suspended
  blocked
}

model Role {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                    String    @map("org_id") @db.Uuid
  name                     String
  isDefault                Boolean   @default(false) @map("is_default")
  permissions              String[]
  createdBy                String?   @map("created_by") @db.Uuid
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime? @map("deleted_at") @db.Timestamptz

  organization             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userRoles                UserRole[]
  creator                  User?        @relation("RoleCreator", fields: [createdBy], references: [id])

  @@unique([orgId, name])
  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([deletedAt])
  @@map("roles")
}

model UserRole {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                    String   @map("org_id") @db.Uuid
  userId                   String   @map("user_id") @db.Uuid
  roleId                   String   @map("role_id") @db.Uuid
  assignedBy               String?  @map("assigned_by") @db.Uuid
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                     Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner                 User?        @relation("RoleAssigner", fields: [assignedBy], references: [id])

  @@unique([orgId, userId, roleId])
  @@index([orgId])
  @@map("user_roles")
}

model EndUser {
  id                       String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                    String       @map("org_id") @db.Uuid
  externalId               String?      @map("external_id")
  name                     String?
  email                    String?
  phone                    String?
  avatarUrl                String?      @map("avatar_url")
  fcmToken                 String?      @map("fcm_token")
  whatsappNumber           String?      @map("whatsapp_number")
  tags                     String[]
  attributes               Json?        @default("{}")
  isSubscribedEmail        Boolean      @default(true) @map("is_subscribed_email")
  isSubscribedSms          Boolean      @default(true) @map("is_subscribed_sms")
  isSubscribedWhatsapp     Boolean      @default(true) @map("is_subscribed_whatsapp")
  isSubscribedPush         Boolean      @default(true) @map("is_subscribed_push")
  status                   EndUserStatus @default(active)
  createdAt                DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime?    @map("deleted_at") @db.Timestamptz

  // ─── Auth Fields (Phase 0) ──────────────────────────────────────────────────
  passwordHash             String?      @map("password_hash")
  isPhoneVerified          Boolean      @default(false) @map("is_phone_verified")
  onboardingStep           Int          @default(0) @map("onboarding_step") // 0=new, 1=phone_entered, 2=otp_verified, 3=details_filled, 4=complete
  isEmailVerified          Boolean      @default(false) @map("is_email_verified")
  lastLoginAt              DateTime?    @map("last_login_at") @db.Timestamptz
  lastLoginIp              String?      @map("last_login_ip")
  referralCode             String?      @map("referral_code")

  organization             Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  segmentMembers           SegmentMember[]
  notifications            Notification[]            @relation("EndUserNotifications")
  campaignLogs             CampaignLog[]
  paymentCustomers         PaymentCustomer[]         @relation("PaymentCustomerEndUser")
  orders                   Order[]                   @relation("OrderEndUser")
  subscriptions            Subscription[]            @relation("SubscriptionEndUser")
  payments                 Payment[]                 @relation("PaymentEndUser")
  refreshTokens            EndUserRefreshToken[]
  otpVerifications         EndUserOtpVerification[]
  verifications            Verification[]
  addresses                EndUserAddress[]
  carts                    Cart[]
  commerceOrders           CommerceOrder[]
  loyaltyAccounts          LoyaltyAccount[]
  loyaltyRedemptions       LoyaltyRedemption[]
  discountCouponUsages     DiscountCouponUsage[]
  referralsGiven           Referral[]             @relation("ReferralReferrer")
  referralsReceived        Referral[]             @relation("ReferralReferee")
  // ─── Phase 5 Relations ───────────────────────────────────────────────────
  reviews                  Review[]
  reviewVotes              ReviewVote[]
  giftCardsPurchased       GiftCard[]             @relation("GiftCardPurchaser")
  reservations             Reservation[]
  supportTickets           SupportTicket[]
  // ─── Phase 6 Relations ───────────────────────────────────────────────────
  conversationSessions     ConversationSession[]
  // ─── Hospitality Relations ───────────────────────────────────────────────
  propertyBookings         PropertyBooking[]
  // ─── InstaMovieMart Relations ──────────────────────────────────────────────
  movieEntitlements        MovieEntitlement[]
  watchProgress            WatchProgress[]      @relation("EndUserWatchProgress")
  watchlists               Watchlist[]
  // ─── PPM Billing Relations ──────────────────────────────────────────────
  walletBalances           WalletBalance[]
  walletTransactions       WalletTransaction[]
  watchSessions            WatchSession[]
  // ─── PlayFlix Room Relations ─────────────────────────────────────────
  hostedRooms              PlayFlixRoom[]          @relation("PlayFlixRoomHost")
  roomViewerSessions       PlayFlixRoomViewer[]    @relation("PlayFlixRoomViewerEndUser")
  roomMessages             PlayFlixRoomMessage[]   @relation("PlayFlixRoomMessageEndUser")
  hostEarnings             HostEarning[]        @relation("HostEarningEndUser")
  connectedSources         ConnectedSource[]    @relation("EndUserConnectedSources")
  // ─── Meal Subscriptions ─────────────────────────────────────────────────
  mealSubscriptions        MealSubscription[]
  // ─── Aurum Banking Relations ──────────────────────────────────────────
  kycVerifications         KycVerification[]
  bankAccounts             BankAccount[]
  beneficiaries            Beneficiary[]
  bankCards                BankCard[]
  fixedDeposits            FixedDeposit[]
  // ─── SubRadar Relations ───────────────────────────────────────────────
  gmailAccounts            GmailAccount[]           @relation("EndUserGmailAccounts")
  trackedSubscriptions     TrackedSubscription[]    @relation("EndUserTrackedSubscriptions")
  subscriptionAlerts       SubscriptionAlert[]      @relation("EndUserSubscriptionAlerts")
  subscriptionSuggestions  SubscriptionSuggestion[] @relation("EndUserSubscriptionSuggestions")

  @@unique([orgId, externalId])
  @@unique([orgId, email])
  @@unique([orgId, phone])
  @@unique([orgId, referralCode])
  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([deletedAt])
  @@map("end_users")
}

enum EndUserStatus {
  active
  unsubscribed
  blocked
}

enum PlayFlixRoomStatus {
  waiting
  live
  ended

  @@map("WatchRoomStatus")
}

enum PlayFlixRoomPrivacy {
  public
  private

  @@map("WatchRoomPrivacy")
}

enum PlayFlixRoomVibe {
  chill
  serious
  party
  commentary

  @@map("WatchRoomVibe")
}

enum PlayFlixRoomViewerMode {
  sync
  solo

  @@map("WatchRoomViewerMode")
}

model Segment {
  id                       String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                    String      @map("org_id") @db.Uuid
  name                     String
  description              String?
  type                     SegmentType @default(static)
  conditions               Json?
  endUserCount             Int         @default(0) @map("end_user_count")
  createdBy                String?     @map("created_by") @db.Uuid
  createdAt                DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime?   @map("deleted_at") @db.Timestamptz

  organization             Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator                  User?           @relation("SegmentCreator", fields: [createdBy], references: [id])
  members                  SegmentMember[]
  campaigns                Campaign[]

  @@index([orgId])
