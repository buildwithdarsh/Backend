// Marketplace Module (generic — used by SideKaam, future orgs, etc.)
// ═══════════════════════════════════════════════════════════════════════════════

model MarketplaceProfile {
  id             String   @id @default(cuid())
  userId         String
  orgId          String
  userType       String   // experiencer | provider
  categories     String[]
  subcategories  String[]
  city           String
  workMode       String   @default("both")
  hourlyRateMin  Float    @default(0)
  hourlyRateMax  Float    @default(0)
  hoursBand      String?
