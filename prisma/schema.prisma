// ═══════════════════════════════════════════════════════════════════════════
// ─── Commerce Inventory & Supply Chain ────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════

model Supplier {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  name         String
  contactName  String    @map("contact_name")
  phone        String
  email        String?
  leadTimeDays Int       @default(1) @map("lead_time_days")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ingredients    Ingredient[]
  purchaseOrders PurchaseOrder[]

  @@index([orgId])
  @@map("suppliers")
}

model Ingredient {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  name         String
  unit         String   @db.VarChar(30) // kg, g, litre, ml, pcs, etc.
  currentStock Decimal  @default(0) @map("current_stock") @db.Decimal(12, 3)
  minStock     Decimal  @default(0) @map("min_stock") @db.Decimal(12, 3)
  costPerUnit  Decimal  @default(0) @map("cost_per_unit") @db.Decimal(12, 2)
  supplierId   String?  @map("supplier_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization       Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supplier           Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockAlerts        StockAlert[]
  wasteLogs          WasteLog[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([orgId])
  @@map("ingredients")
}

model StockAlert {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  ingredientId   String   @map("ingredient_id") @db.Uuid
  ingredientName String   @map("ingredient_name")
  type           String   @db.VarChar(30) // low_stock, out_of_stock
  message        String
  isResolved     Boolean  @default(false) @map("is_resolved")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, isResolved])
  @@map("stock_alerts")
}

model WasteLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  ingredientId   String   @map("ingredient_id") @db.Uuid
  ingredientName String   @map("ingredient_name")
  quantity       Decimal  @db.Decimal(12, 3)
  reason         String
  costImpact     Decimal  @default(0) @map("cost_impact") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("waste_logs")
}

model PurchaseOrder {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  poNumber     String    @map("po_number")
  supplierId   String    @map("supplier_id") @db.Uuid
  supplierName String    @map("supplier_name")
  status       String    @default("draft") @db.VarChar(20) // draft, sent, received, cancelled
  totalAmount  Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supplier     Supplier             @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]

  @@unique([orgId, poNumber])
  @@index([orgId])
  @@index([orgId, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String  @map("org_id") @db.Uuid
  purchaseOrderId String  @map("purchase_order_id") @db.Uuid
  ingredientId    String  @map("ingredient_id") @db.Uuid
  ingredientName  String  @map("ingredient_name")
  quantity        Decimal @db.Decimal(12, 3)
  unitPrice       Decimal @map("unit_price") @db.Decimal(12, 2)
  total           Decimal @db.Decimal(12, 2)

  organization  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

