// ═══════════════════════════════════════════════════════════════════════════
// ─── Aurum Banking ──────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════

// ─── Enums ──────────────────────────────────────────────────────────────

enum KycStatus {
  pending
  submitted
  verified
  rejected
  expired
}

enum KycDocumentType {
  aadhaar
  pan
  passport
  voter_id
  driving_license
}

enum BankAccountType {
  savings
  current
}

enum BankAccountStatus {
  active
  frozen
  closed
  dormant
}

enum TransferMode {
  neft
  rtgs
  imps
  upi
  swift
  internal
}

enum TransferStatus {
  initiated
  processing
  completed
  failed
  reversed
}

enum CardType {
  debit
  credit
}

enum CardVariant {
  virtual
  physical
}

enum CardStatus {
  active
  blocked
  expired
  cancelled
}

enum ScheduledTransferFrequency {
  once
  daily
  weekly
  monthly
}

enum ScheduledTransferStatus {
  active
  paused
  completed
  cancelled
}

enum BillPaymentStatus {
  pending
  paid
  failed
}

enum FixedDepositStatus {
  active
  matured
  closed_premature
  renewed
}

// ─── KYC Verification (FR-001) ─────────────────────────────────────────

model KycVerification {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String          @map("org_id") @db.Uuid
  endUserId      String          @map("end_user_id") @db.Uuid
  documentType   KycDocumentType @map("document_type")
  documentNumber String          @map("document_number") @db.VarChar(64)
  documentUrl    String?         @map("document_url")
  selfieUrl      String?         @map("selfie_url")
  status         KycStatus       @default(pending)
  verifiedAt     DateTime?       @map("verified_at") @db.Timestamptz
  rejectionNote  String?         @map("rejection_note") @db.Text
  metadata       Json?           @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endUser      EndUser      @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@unique([orgId, endUserId, documentType])
  @@index([orgId])
  @@index([orgId, status])
  @@map("kyc_verifications")
}

// ─── Bank Accounts (FR-007 to FR-011) ──────────────────────────────────

model BankAccount {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String            @map("org_id") @db.Uuid
  endUserId       String            @map("end_user_id") @db.Uuid
  accountNumber   String            @map("account_number") @db.VarChar(20)
  ifscCode        String            @map("ifsc_code") @db.VarChar(11)
  accountType     BankAccountType   @map("account_type")
  status          BankAccountStatus @default(active)
  nickname        String?           @db.VarChar(50)
  balance         Decimal           @default(0) @db.Decimal(18, 2)
  currency        String            @default("INR") @db.VarChar(3)
  autoSweepEnabled   Boolean        @default(false) @map("auto_sweep_enabled")
  autoSweepThreshold Decimal?       @map("auto_sweep_threshold") @db.Decimal(18, 2)
  isPrimary       Boolean           @default(false) @map("is_primary")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz

  organization       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endUser            EndUser             @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  transactions       BankTransaction[]
  sentTransfers      ScheduledTransfer[] @relation("scheduled_sender")
  fixedDeposits      FixedDeposit[]
  billPayments       BillPayment[]

  @@unique([orgId, accountNumber])
  @@index([orgId, endUserId])
  @@index([orgId, status])
  @@map("bank_accounts")
}

// ─── Bank Transactions ─────────────────────────────────────────────────

model BankTransaction {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  accountId       String         @map("account_id") @db.Uuid
  endUserId       String         @map("end_user_id") @db.Uuid
  type            String         @db.VarChar(20) // credit, debit
  mode            TransferMode?
  amount          Decimal        @db.Decimal(18, 2)
  balanceAfter    Decimal        @map("balance_after") @db.Decimal(18, 2)
  currency        String         @default("INR") @db.VarChar(3)
  description     String         @db.Text
  referenceNumber String?        @map("reference_number") @db.VarChar(64)
  counterpartyName    String?    @map("counterparty_name")
  counterpartyAccount String?    @map("counterparty_account") @db.VarChar(20)
  counterpartyIfsc    String?    @map("counterparty_ifsc") @db.VarChar(11)
  status          TransferStatus @default(completed)
  category        String?        @db.VarChar(50)
  metadata        Json?          @default("{}")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  account      BankAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([orgId, accountId])
  @@index([orgId, endUserId])
  @@index([orgId, accountId, createdAt])
  @@index([orgId, category])
  @@map("bank_transactions")
}

// ─── Beneficiaries (FR-012 to FR-017) ──────────────────────────────────

model Beneficiary {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  endUserId       String   @map("end_user_id") @db.Uuid
  name            String
  accountNumber   String   @map("account_number") @db.VarChar(20)
  ifscCode        String   @map("ifsc_code") @db.VarChar(11)
  bankName        String?  @map("bank_name")
  upiId           String?  @map("upi_id") @db.VarChar(100)
  nickname        String?  @db.VarChar(50)
  isFavorite      Boolean  @default(false) @map("is_favorite")
  transferLimit   Decimal? @map("transfer_limit") @db.Decimal(18, 2)
  isVerified      Boolean  @default(false) @map("is_verified")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endUser      EndUser      @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@unique([orgId, endUserId, accountNumber])
  @@index([orgId, endUserId])
  @@map("beneficiaries")
}

// ─── Bank Cards (FR-018 to FR-022) ────────────────────────────────────

model BankCard {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String      @map("org_id") @db.Uuid
  endUserId         String      @map("end_user_id") @db.Uuid
  accountId         String?     @map("account_id") @db.Uuid
  cardType          CardType    @map("card_type")
  variant           CardVariant
  status            CardStatus  @default(active)
  lastFourDigits    String      @map("last_four_digits") @db.VarChar(4)
  cardNetwork       String      @map("card_network") @db.VarChar(20) // visa, mastercard, rupay
  expiryMonth       Int         @map("expiry_month")
  expiryYear        Int         @map("expiry_year")
  nameOnCard        String      @map("name_on_card")
  dailyLimit        Decimal     @default(100000) @map("daily_limit") @db.Decimal(18, 2)
  internationalEnabled Boolean  @default(false) @map("international_enabled")
  internationalFrom DateTime?   @map("international_from") @db.Timestamptz
  internationalUntil DateTime?  @map("international_until") @db.Timestamptz
  contactlessEnabled Boolean    @default(true) @map("contactless_enabled")
  atmWithdrawalLimit Decimal    @default(25000) @map("atm_withdrawal_limit") @db.Decimal(18, 2)
  onlineEnabled     Boolean     @default(true) @map("online_enabled")
  metadata          Json?       @default("{}")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endUser      EndUser      @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@index([orgId, endUserId])
  @@index([orgId, status])
  @@map("bank_cards")
}

// ─── Fixed Deposits (FR-011) ──────────────────────────────────────────

model FixedDeposit {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String             @map("org_id") @db.Uuid
  endUserId       String             @map("end_user_id") @db.Uuid
  accountId       String             @map("account_id") @db.Uuid
  fdNumber        String             @map("fd_number") @db.VarChar(20)
  principalAmount Decimal            @map("principal_amount") @db.Decimal(18, 2)
  interestRate    Decimal            @map("interest_rate") @db.Decimal(5, 2)
  tenureDays      Int                @map("tenure_days")
  maturityAmount  Decimal            @map("maturity_amount") @db.Decimal(18, 2)
  maturityDate    DateTime           @map("maturity_date") @db.Timestamptz
  status          FixedDepositStatus @default(active)
  autoRenew       Boolean            @default(false) @map("auto_renew")
  closedAt        DateTime?          @map("closed_at") @db.Timestamptz
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endUser      EndUser      @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  account      BankAccount  @relation(fields: [accountId], references: [id])

  @@unique([orgId, fdNumber])
  @@index([orgId, endUserId])
  @@index([orgId, status])
  @@map("fixed_deposits")
}

// ─── Scheduled / Recurring Transfers (FR-014) ─────────────────────────

model ScheduledTransfer {
  id              String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String                     @map("org_id") @db.Uuid
  endUserId       String                     @map("end_user_id") @db.Uuid
  senderAccountId String                     @map("sender_account_id") @db.Uuid
  beneficiaryName String                     @map("beneficiary_name")
  beneficiaryAccount String                  @map("beneficiary_account") @db.VarChar(20)
  beneficiaryIfsc String                     @map("beneficiary_ifsc") @db.VarChar(11)
  amount          Decimal                    @db.Decimal(18, 2)
  mode            TransferMode
  frequency       ScheduledTransferFrequency
  status          ScheduledTransferStatus    @default(active)
  description     String?                    @db.Text
  nextExecutionAt DateTime                   @map("next_execution_at") @db.Timestamptz
  lastExecutedAt  DateTime?                  @map("last_executed_at") @db.Timestamptz
  endsAt          DateTime?                  @map("ends_at") @db.Timestamptz
  executionCount  Int                        @default(0) @map("execution_count")
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime                   @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  senderAccount BankAccount  @relation("scheduled_sender", fields: [senderAccountId], references: [id])

  @@index([orgId, endUserId])
  @@index([orgId, status, nextExecutionAt])
  @@map("scheduled_transfers")
}

// ─── Bill Payments (FR-015) ───────────────────────────────────────────

model BillPayment {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String            @map("org_id") @db.Uuid
  endUserId       String            @map("end_user_id") @db.Uuid
  accountId       String            @map("account_id") @db.Uuid
  billerCategory  String            @map("biller_category") @db.VarChar(50) // electricity, mobile, insurance, etc.
  billerName      String            @map("biller_name")
  billerId        String?           @map("biller_id") @db.VarChar(64)
  consumerNumber  String            @map("consumer_number") @db.VarChar(64)
  amount          Decimal           @db.Decimal(18, 2)
  status          BillPaymentStatus @default(pending)
  referenceNumber String?           @map("reference_number") @db.VarChar(64)
  paidAt          DateTime?         @map("paid_at") @db.Timestamptz
  metadata        Json?             @default("{}")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  account      BankAccount  @relation(fields: [accountId], references: [id])

  @@index([orgId, endUserId])
  @@index([orgId, billerCategory])
  @@map("bill_payments")
}

// ─── Budgets & Analytics (FR-023 to FR-027) ───────────────────────────

model Budget {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  endUserId    String   @map("end_user_id") @db.Uuid
