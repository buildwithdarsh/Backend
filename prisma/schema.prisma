// ─── Cross-app dakshina broker ──────────────────────────────────────────────
// External apps (e.g. Khwahish) cannot host Razorpay Checkout because their
// origins aren't whitelisted. They mint an encrypted DakshinaTokenPayload and
// embed techzunction.com/pay in an iframe; the Website opens Checkout (origin
// is whitelisted), Backend validates the token + Razorpay signature, and the
// originating app polls for status.

enum DakshinaPaymentStatus {
  pending
  captured
  failed
  expired

  @@map("dakshina_payment_status")
}

model DakshinaPayment {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app                 String                @db.VarChar(40)
  callbackId          String                @unique @map("callback_id")
  externalUserRef     String                @map("external_user_ref") @db.VarChar(80)
  fingerprint         String                @db.VarChar(128)
  amountInr           Int                   @map("amount_inr")
  status              DakshinaPaymentStatus @default(pending)
  razorpayOrderId     String?               @map("razorpay_order_id")
  razorpayPaymentId   String?               @map("razorpay_payment_id")
  failureReason       String?               @map("failure_reason")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz
  verifiedAt          DateTime?             @map("verified_at") @db.Timestamptz
  expiresAt           DateTime              @map("expires_at") @db.Timestamptz

  @@index([app, status])
  @@index([fingerprint])
  @@map("dakshina_payments")
}
